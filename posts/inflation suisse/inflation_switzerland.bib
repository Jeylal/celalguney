@article{baltensperger_historical_2016,
	title = {The historical origins of the safe haven status of the Swiss franc},
	volume = {67},
	rights = {http://www.econstor.eu/dspace/Nutzungsbedingungen},
	issn = {0004-8216},
	url = {https://www.econstor.eu/handle/10419/231229},
	abstract = {An empirical analysis of international interest rates and of the behavior of the exchange rate of the Swiss franc since 1850 leads to the conclusion that World War I marks the origin of the strong currency and safe haven status of the Swiss franc. Before World War I, interest rates point to a weakness of the Swiss currency against the pound, the guilder and French franc (from 1881 to 1913) that is shared with the German mark. Thereafter, we see the pattern of the Swiss interest rate island develop and become especially pronounced during the Bretton Woods years. Deviations from metallic parities confirm these findings. For the period after World War I, we establish a strong and stable real and nominal trend appreciation against the pound and the dollar that reflects, to a sizeable extent, inflation differentials.},
	pages = {1--30},
	number = {2},
	journaltitle = {Aussenwirtschaft},
	publisher = {St.Gallen: Universität St.Gallen, Schweizerisches Institut für Aussenwirtschaft und Angewandte Wirtschaftsforschung ({SIAW}-{HSG})},
	author = {Baltensperger, Ernst and Kugler, Peter},
	urldate = {2026-05-29},
	date = {2016},
	file = {Full Text PDF:C\:\\Users\\gueney\\Zotero\\storage\\SA36P2CP\\Baltensperger et Kugler - 2016 - The historical origins of the safe haven status of the Swiss franc.pdf:application/pdf},
}

@article{yesin_capital_2017,
	title = {Capital Flows and the Swiss Franc},
	volume = {153},
	issn = {2235-6282},
	url = {https://doi.org/10.1007/BF03399513},
	doi = {10.1007/BF03399513},
	abstract = {The Swiss franc is known to appreciate strongly during financial market turmoil, demonstrating its status as a typical safe haven currency. One possible mechanism behind this appreciation during times of global turmoil is assumed to be higher capital inflows to Switzerland. This paper attempts to find some empirical evidence for this presumption. The analysis reveals that capital flow variables are not necessarily coincident with the movements of the Swiss franc. Interest rate differentials, a traditional determinant of exchange rates, co-move only weakly with Swiss franc movements. However, a robust and stronger link between variables that capture global or regional market uncertainty and movements of the Swiss franc is observed. Specifically, the information channel rather than new cross-border investment is found to be coincident with the Swiss franc. The weak link between capital flows and the exchange rate is confirmed to some extent for some other countries.},
	pages = {403--436},
	number = {4},
	journaltitle = {Swiss Journal of Economics and Statistics},
	shortjournal = {Swiss J Economics Statistics},
	author = {Yeşin, Pınar},
	urldate = {2026-05-29},
	date = {2017-10-01},
	langid = {english},
	keywords = {F31, Exchange rate, F21, F32, gross capital flows, {JEL}-ckssification, net flows, private flows, safe haven currency},
	file = {Full Text PDF:C\:\\Users\\gueney\\Zotero\\storage\\U2S45DEY\\Yeşin - 2017 - Capital Flows and the Swiss Franc.pdf:application/pdf},
}

